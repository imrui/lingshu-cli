# 默认按文本处理，统一 LF 行尾，跨平台安全
* text=auto eol=lf

# Windows 批处理须保持 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 可执行入口必须 LF（避免 npm 发布到 Linux/macOS 后 shebang 解释失败）
bin/** text eol=lf
*.sh text eol=lf
*.mjs text eol=lf
*.js text eol=lf

# 二进制保护
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.tgz binary
